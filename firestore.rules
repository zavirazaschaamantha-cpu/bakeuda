rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read & write to our application collections
    match /users/{docId} {
      allow read, write: if true;
    }
    match /surat_masuk/{docId} {
      allow read, write: if true;
    }
    match /surat_keluar/{docId} {
      allow read, write: if true;
    }
    match /disposisi/{docId} {
      allow read, write: if true;
    }
    match /agenda/{docId} {
      allow read, write: if true;
    }
    match /reminders/{docId} {
      allow read, write: if true;
    }
    match /arsip/{docId} {
      allow read, write: if true;
    }
    match /pengumuman/{docId} {
      allow read, write: if true;
    }
    match /pegawai/{docId} {
      allow read, write: if true;
    }
    match /audit_logs/{docId} {
      allow read, write: if true;
    }
    match /notifications/{docId} {
      allow read, write: if true;
    }
  }
}
